generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum BattleMode {
  PVP
  DAILY
  RAID
}

enum Difficulty {
  EASY
  NORMAL
  HARD
}

enum PvpStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  avatar       String?
  bio          String?
  faculty      String?
  batch        String?

  xp           Int       @default(0)
  level        Int       @default(1)
  streak       Int       @default(0)
  lastActiveAt DateTime?
  eloPoints    Int       @default(1000)
  division     String    @default("Bronze")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens   RefreshToken[]
  battleResults   BattleResult[]
  pvpChallenger   PvpSession[]          @relation("Challenger")
  pvpOpponent     PvpSession[]          @relation("Opponent")
  pvpAnswers      PvpAnswer[]
  quizSubmissions DailyQuizSubmission[]
  forumPosts      ForumPost[]
  postLikes       ForumPostLike[]
  userItems       UserItem[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Question {
  id            String     @id @default(uuid())
  text          String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  topic         String
  difficulty    Difficulty @default(NORMAL)
  createdAt     DateTime   @default(now())

  dailyQuizQuestions DailyQuizQuestion[]
  pvpAnswers         PvpAnswer[]
}

model DailyQuiz {
  id        String   @id @default(uuid())
  quizDate  String   @unique
  createdAt DateTime @default(now())

  questions   DailyQuizQuestion[]
  submissions DailyQuizSubmission[]
}

model DailyQuizQuestion {
  quizId     String
  questionId String
  order      Int

  quiz     DailyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question  @relation(fields: [questionId], references: [id])

  @@id([quizId, questionId])
}

model DailyQuizSubmission {
  id          String   @id @default(uuid())
  userId      String
  quizId      String
  correct     Int
  wrong       Int
  avgTime     Float
  xpGained    Int
  submittedAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id])
  quiz DailyQuiz @relation(fields: [quizId], references: [id])

  @@unique([userId, quizId])
}

model BattleResult {
  id          String      @id @default(uuid())
  userId      String
  mode        BattleMode
  difficulty  Difficulty?
  correct     Int
  wrong       Int
  timeElapsed Float
  xpGained    Int
  eloChange   Int         @default(0)
  opponentId  String?
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, mode])
  @@index([createdAt])
}

model PvpSession {
  id           String    @id @default(uuid())
  challengerId String
  opponentId   String
  status       PvpStatus @default(WAITING)
  winnerId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  endedAt      DateTime?

  challenger User       @relation("Challenger", fields: [challengerId], references: [id])
  opponent   User       @relation("Opponent", fields: [opponentId], references: [id])
  answers    PvpAnswer[]
}

model PvpAnswer {
  id         String  @id @default(uuid())
  sessionId  String
  userId     String
  questionId String
  answer     String
  timeTaken  Float
  correct    Boolean

  session  PvpSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id])
  question Question   @relation(fields: [questionId], references: [id])

  @@index([sessionId])
}

model Item {
  id          String     @id @default(uuid())
  name        String     @unique
  description String
  ability     String
  rarity      ItemRarity
  imageKey    String?

  userItems UserItem[]
}

model UserItem {
  id       String @id @default(uuid())
  userId   String
  itemId   String
  quantity Int    @default(1)

  user User @relation(fields: [userId], references: [id])
  item Item @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
}

model ForumPost {
  id        String    @id @default(uuid())
  userId    String
  channel   String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User            @relation(fields: [userId], references: [id])
  likes ForumPostLike[]

  @@index([channel])
  @@index([userId])
}

model ForumPostLike {
  postId String
  userId String

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id])

  @@id([postId, userId])
}
