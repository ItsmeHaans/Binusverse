generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BattleMode {
  PVP
  DAILY
  RAID
}

enum PvpStatus {
  WAITING
  ACTIVE
  FINISHED
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  faculty      String
  batch        String
  avatar       String?
  bio          String?
  level        Int       @default(1)
  xp           Int       @default(0)
  streak       Int       @default(0)
  lastActiveAt DateTime?
  gpa          Float     @default(0.0)
  attendance   Int       @default(0)
  division     String?
  rank         Int?
  eloPoints    Int       @default(1000)
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens      RefreshToken[]
  battleResults      BattleResult[]
  classes            Class[]
  gpaHistory         GpaHistory[]
  missions           Mission[]
  forumPosts         ForumPost[]
  forumComments      ForumComment[]
  postLikes          ForumPostLike[]
  commentLikes       ForumCommentLike[]
  skillUpgrades      SkillUpgrade[]
  quizSubmissions    DailyQuizSubmission[]
  pvpAsChallenger    PvpSession[]          @relation("Challenger")
  pvpAsOpponent      PvpSession[]          @relation("Opponent")
  pvpAnswers         PvpAnswer[]
  learnAnalysis      LearnAnalysis?
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BattleResult {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  mode        BattleMode
  correct     Int
  wrong       Int
  timeElapsed Int
  opponentId  String?
  difficulty  String?
  xpGained    Int        @default(0)
  createdAt   DateTime   @default(now())

  @@index([userId])
}

model Class {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  className String
  classCode String?
  semester  String
  passed    Boolean @default(false)

  @@index([userId])
}

model GpaHistory {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  semester      String
  ipValue       Float
  classesPassed Int
  totalClasses  Int
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Mission {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  source      String    @default("manual")
  status      String    @default("ongoing")
  imageUrl    String?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model ForumPost {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  forumType String
  content   String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  comments ForumComment[]
  likes    ForumPostLike[]

  @@index([forumType])
  @@index([userId])
}

model ForumComment {
  id        String    @id @default(uuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  content   String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  likes ForumCommentLike[]
}

model ForumPostLike {
  id        String    @id @default(uuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
}

model ForumCommentLike {
  id        String       @id @default(uuid())
  commentId String
  comment   ForumComment @relation(fields: [commentId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([commentId, userId])
}

model News {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageUrl  String?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyQuiz {
  id            String   @id @default(uuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  aiGenerated   Boolean  @default(true)
  topic         String?
  difficulty    String   @default("normal")
  quizDate      String
  createdAt     DateTime @default(now())

  pvpAnswers PvpAnswer[]

  @@index([quizDate])
  @@index([difficulty])
}

model DailyQuizSubmission {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  quizDate  String
  correct   Int
  wrong     Int
  avgTime   Float
  xpGained  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, quizDate])
  @@index([userId])
}

model PvpSession {
  id           String    @id @default(uuid())
  challengerId String
  challenger   User      @relation("Challenger", fields: [challengerId], references: [id])
  opponentId   String
  opponent     User      @relation("Opponent", fields: [opponentId], references: [id])
  status       PvpStatus @default(WAITING)
  winnerId     String?
  createdAt    DateTime  @default(now())
  endedAt      DateTime?

  answers PvpAnswer[]
}

model PvpAnswer {
  id         String     @id @default(uuid())
  sessionId  String
  session    PvpSession @relation(fields: [sessionId], references: [id])
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  questionId String
  question   DailyQuiz  @relation(fields: [questionId], references: [id])
  answer     String
  timeTaken  Float
  correct    Boolean
  createdAt  DateTime   @default(now())

  @@index([sessionId])
  @@index([userId])
}

model SkillUpgrade {
  id             String   @id @default(uuid())
  title          String
  youtubeUrl     String
  topicTag       String?
  aiSuggestedFor String?
  user           User?    @relation(fields: [aiSuggestedFor], references: [id])
  createdAt      DateTime @default(now())

  @@index([aiSuggestedFor])
}

model LearnAnalysis {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  strength  String[]
  weakness  String[]
  updatedAt DateTime @default(now())
}
